# Configuración del agente Hermes
# Copiar a config.env y ajustar valores antes de instalar.

AGENT_NAME=hermes
AGENT_USER=hermes
AGENT_HOME=/home/hermes
INSTALL_DIR=/opt/hermes
REPO_ROOT=

# Repositorio del agente Hermes
HERMES_REPO=https://github.com/nousresearch/hermes-agent
HERMES_BRANCH=main

# Vault de Obsidian — memoria persistente del agente
OBSIDIAN_VAULT_REPO=
OBSIDIAN_VAULT_BRANCH=main
OBSIDIAN_VAULT_DIR=obsidian-vault

# Ruta al bootstrap que el agente debe leer al arrancar
BOOTSTRAP_FILE=bootstrap.md
