# Configuración del agente Hermes
# Copiar a config.env y ajustar valores antes de instalar.
#
# Usuario del agente: definir en init/config.env (compartido con setup-vps).
# Ver init/config.env.example.

AGENT_NAME=hermes
INSTALL_DIR=/opt/hermes
REPO_ROOT=

# Runtime del agente Hermes — instalador oficial de Nous Research
HERMES_INSTALL_URL=https://hermes-agent.nousresearch.com/install.sh

# Ruta al bootstrap que el agente debe leer al arrancar
BOOTSTRAP_FILE=bootstrap.md
