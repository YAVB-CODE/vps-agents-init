# Configuración del init del VPS
# Copiar a config.env y ajustar valores antes de ejecutar bin/setup-vps

# Usuario dedicado del agente (creado durante init)
AGENT_USER=hermes
AGENT_HOME=/home/hermes

# Sudo sin contraseña para operaciones de sistema (recomendado en VPS dedicado)
AGENT_SUDO_NOPASSWD=true

# Contraseña de login del agente (opcional; si no se define, solo SSH)
# AGENT_PASSWORD=tu-password-seguro

# Identidad git del agente (git clone/pull como AGENT_USER)
AGENT_GIT_NAME=hermes
AGENT_GIT_EMAIL=hermes@localhost

# Clave SSH pública del agente (opcional; usar una de las dos opciones)
# AGENT_SSH_KEY="ssh-ed25519 AAAA... user@host"
# AGENT_SSH_KEY_FILE=/root/.ssh/authorized_keys

# Si no hay clave configurada, copiar authorized_keys de root al nuevo usuario
AGENT_COPY_ROOT_SSH_KEYS=true

# Docker Engine (repositorio oficial)
INSTALL_DOCKER=true
