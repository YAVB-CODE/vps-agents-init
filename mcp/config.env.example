# Variables de entorno de los servidores MCP.
# Solo NOMBRES de variables como referencia. Los valores reales se generan
# con install-mcp.sh y viven en el archivo de secretos (.mcp.env, permisos 600),
# que NO se versiona.

# Archivo donde install-mcp.sh escribe los secretos (override opcional).
# MCP_SECRETS_FILE=/opt/hermes/.mcp.env

# --- Linear (AUTH_TYPE=token) ---
LINEAR_API_KEY=

# --- Sentry (AUTH_TYPE=oauth) ---
SENTRY_ACCESS_TOKEN=
