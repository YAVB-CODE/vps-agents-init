# Configuración del addon Obsidian Vault
# Copiar a config.env y ajustar antes de instalar.

# Ruta del vault (default: ~/obsidian-vault del AGENT_USER)
# VAULT_DIR=/home/hermes/obsidian-vault

# Repositorio git del vault (opcional; sin repo se crea directorio vacío)
OBSIDIAN_VAULT_REPO=https://github.com/YAVB-CODE/obsidian-vault-work
OBSIDIAN_VAULT_BRANCH=main

# .env del agente donde se registra VAULT_DIR (requiere agente instalado)
AGENT_ENV_FILE=/opt/hermes/.env
